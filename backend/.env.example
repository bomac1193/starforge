# Starforge Backend Environment Variables

# AI Generation (Choose ONE provider)
# Anthropic Claude (Recommended - more sophisticated output)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OR OpenAI GPT-4 (Alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
PORT=5000

# Spotify API (for audio features enrichment)
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# TIZITA Database Path (for Visual DNA)
TIZITA_DB_PATH=/path/to/tizita/backend/clarosa.db
TIZITA_STORAGE=/path/to/tizita/backend/storage

# LoRA Training (via Replicate)
# Get API token at: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_token_here
# Optional: Webhook for training status updates
REPLICATE_WEBHOOK_URL=https://your-domain.com/api/lora/webhook
